<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Lab 96 Telemetry Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --border: rgba(255, 255, 255, 0.1);
            --text-main: #f8fafc;
            --temp-accent: #f97316;
            --hum-accent: #06b6d4;
        }
        body {
            background-color: var(--bg);
            background-image: radial-gradient(at 0% 0%, #1e293b 0px, transparent 50%),
                              radial-gradient(at 100% 100%, #0f172a 0px, transparent 50%);
            color: var(--text-main);
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0; padding: 40px;
        }
        header { text-align: center; margin-bottom: 40px; }
        h1 { font-size: 2.5rem; margin: 0; color: #fff; text-transform: uppercase; letter-spacing: 2px; }
        h2 { font-size: 1.1rem; opacity: 0.7; font-weight: 300; margin-top: 10px; }
        
        .dashboard-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 25px; max-width: 1200px; margin: auto;
        }
        .card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 20px; padding: 30px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        }
        .card h3 { margin: 0 0 20px 0; font-size: 1.2rem; opacity: 0.9; }
        .value { font-size: 3.5rem; font-weight: 700; margin-bottom: 20px; }
        .chart-container { height: 250px; position: relative; }
    </style>
</head>
<body>

<header>
    <h1>Live Polyhouse Node capstone</h1>
    <h2>Temperature and Humidity Monitoring</h2>
</header>

<div class="dashboard-grid">
    <div class="card">
        <h3>Temperature</h3>
        <div id="tempValue" class="value" style="color: var(--temp-accent)">--°C</div>
        <div class="chart-container"><canvas id="tempChart"></canvas></div>
    </div>
    <div class="card">
        <h3>Humidity</h3>
        <div id="humidityValue" class="value" style="color: var(--hum-accent)">--%</div>
        <div class="chart-container"><canvas id="humidityChart"></canvas></div>
    </div>
</div>

<script>
window.addEventListener('load', () => {
    const CONFIG = {
        ENDPOINT: "https://careers.zelbytes.com/api/iot-lab/v1/telemetry",
        KEY: "zil_7lehy3vjludt8pohakklivqyemex3yg9"
    };

    const createChart = (id, color) => new Chart(document.getElementById(id), {
        type: 'line',
        data: { labels: [], datasets: [{ data: [], borderColor: color, backgroundColor: color + '20', fill: true, tension: 0.4, borderWidth: 3 }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { grid: { color: 'rgba(255,255,255,0.05)' } }, x: { grid: { display: false } } } }
    });

    const tempChart = createChart('tempChart', "#f97316");
    const humidityChart = createChart('humidityChart', "#06b6d4");

    async function update() {
        try {
            const res = await fetch(CONFIG.ENDPOINT, { headers: { "X-Iot-Lab-Key": CONFIG.KEY } });
            const json = await res.json();
            const latest = json.data.find(item => item.payload !== null);
            if (!latest) return;

            const payload = typeof latest.payload === "string" ? JSON.parse(latest.payload) : latest.payload;
            const temp = parseFloat(payload.temp_c || 0).toFixed(1);
            const hum = parseFloat(payload.humidity_pct || 0).toFixed(1);

            document.getElementById("tempValue").textContent = temp + "°C";
            document.getElementById("humidityValue").textContent = hum + "%";

            const now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            
            [ {c: tempChart, v: temp}, {c: humidityChart, v: hum} ].forEach(item => {
                item.c.data.labels.push(now);
                item.c.data.datasets[0].data.push(item.v);
                if(item.c.data.labels.length > 10) { item.c.data.labels.shift(); item.c.data.datasets[0].data.shift(); }
                item.c.update();
            });
        } catch(e) { console.error("Update failed", e); }
    }

    setInterval(update, 5000);
    update();
});
</script>
</body>
</html>
